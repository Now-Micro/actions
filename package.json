{
    "name": "now-micro-actions-mcp-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc -p _content/mcp/",
        "start": "node _content/mcp/dist/index.js",
        "dev": "tsx _content/mcp/src/index.ts",
        "inspect": "set DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector npm run dev",
        "dev:docker": "docker-compose build",
        "dev:docker:up": "docker-compose up",
        "test": "npm run build && node --test"
    },
    "dependencies": {
        "@modelcontextprotocol/inspector": "0.16.8",
        "@modelcontextprotocol/sdk": "1.18.2",
        "zod": "^3.23.8",
        "yaml": "^2.5.1"
    },
    "devDependencies": {
        "typescript": "^5.5.4",
        "tsx": "^4.16.2",
        "@types/node": "^20.11.30"
    }
}